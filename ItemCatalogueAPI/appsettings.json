{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "OpenTelemetry": {
    "SamplingRatio": 1.0
  },
  "ConnectionStrings": {
    "local": "Data Source=localhost;Initial Catalog=master;Integrated Security=True;Connect Timeout=30;Encrypt=True;Trust Server Certificate=True;Application Intent=ReadWrite;Multi Subnet Failover=False;Command Timeout=30"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 0,
    "ImportPermitLimit": 5,
    "ImportWindowSeconds": 60
  },
  "ScheduledReset": {
    "Enabled": false,
    "IntervalHours": 24
  },
  "BlobStorage": {
    "ConnectionString": "UseDevelopmentStorage=true",
    "ContainerName": "catalogue-images",
    "ReadSasMinutes": 15
  },
  "Import": {
    "ChunkSize": 25,
    "MaxRows": 1000
  },
  "ImportStorage": {
    "ConnectionString": "UseDevelopmentStorage=true",
    "QueueName": "item-import",
    "PoisonQueueName": "item-import-poison",
    "PayloadContainerName": "catalogue-imports"
  }
}
