<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.Build.Sql/2.1.0">
  <PropertyGroup>
    <Name>Database</Name>
    <DSP>Microsoft.Data.Tools.Schema.Sql.Sql170DatabaseSchemaProvider</DSP>
    <ModelCollation>1033, CI</ModelCollation>
    <TargetDatabaseSet>True</TargetDatabaseSet>
    <ProjectGuid>{1f83091e-bc0a-4725-8755-c867b8ea854c}</ProjectGuid>
  </PropertyGroup>
  <ItemGroup>
    <!-- Post-deploy orchestrator: not a schema object. The :r-included seed
         scripts below are excluded from the default *.sql build glob. -->
    <Build Remove="PostDeploymentScripts\**\*.sql" />
    <PostDeploy Include="PostDeploymentScripts\Script.PostDeployment.sql" />
    <None Include="PostDeploymentScripts\Seed_Location.sql" />
    <None Include="PostDeploymentScripts\Seed_Floor.sql" />
    <None Include="PostDeploymentScripts\Seed_Room.sql" />
    <None Include="PostDeploymentScripts\Seed_Container.sql" />
    <None Include="PostDeploymentScripts\Seed_Door.sql" />
    <None Include="PostDeploymentScripts\Seed_Stair.sql" />
    <None Include="PostDeploymentScripts\Seed_Person.sql" />
    <None Include="PostDeploymentScripts\Seed_Item.sql" />
    <None Include="PostDeploymentScripts\Seed_Tag.sql" />
    <None Include="PostDeploymentScripts\Seed_Collection.sql" />
    <None Include="PostDeploymentScripts\Seed_Cleanup.sql" />
    <!-- Table schema objects (dbo\tables\*.sql) are picked up by the SDK's default *.sql
         build glob; they are intentionally not re-listed here to avoid duplicate Build items. -->
  </ItemGroup>
  <ItemGroup>
    <Folder Include="PostDeploymentScripts\" />
    <Folder Include="bin" />
    <Folder Include="dbo" />
    <Folder Include="dbo\tables" />
    <Folder Include="obj" />
  </ItemGroup>
</Project>